{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CRAcked",
  "version": "0.1.0",
  "identifier": "io.mangoboost.cracked",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CRAcked — Contribution Room, Cracked",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
